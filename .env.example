# ============================================================================
# Hospital Management System - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================================

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
PORT=5000
NODE_ENV=production
LOG_LEVEL=info

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your-secure-password
DB_NAME=hospital_management
DB_POOL_SIZE=10

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================================================
# SESSION CONFIGURATION
# ============================================================================
SESSION_SECRET=your-super-secret-session-key-must-be-32-chars-min
COOKIE_DOMAIN=localhost
SESSION_TIMEOUT=86400000

# ============================================================================
# CORS CONFIGURATION
# ============================================================================
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000,http://127.0.0.1:3000
INTERNAL_SERVICES=http://localhost:5001

# ============================================================================
# ADMIN CONFIGURATION
# ============================================================================
ADMIN_IPS=127.0.0.1,::1,192.168.1.100,192.168.1.101

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================
JWT_SECRET=your-jwt-secret-key-must-be-32-chars-min
BCRYPT_ROUNDS=10
CSRF_TOKEN_LENGTH=32

# ============================================================================
# FILE UPLOAD CONFIGURATION
# ============================================================================
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=pdf,doc,docx,jpg,jpeg,png,txt
UPLOAD_DIR=./uploads

# ============================================================================
# EMAIL CONFIGURATION (for future use)
# ============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@hospital.com

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
LOG_FORMAT=json
LOG_FILE=./logs/app.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=14

# ============================================================================
# RATE LIMITING CONFIGURATION
# ============================================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_IP_MAX=50
RATE_LIMIT_USER_MAX=30
RATE_LIMIT_SENSITIVE_MAX=10
RATE_LIMIT_LOGIN_MAX=5

# ============================================================================
# AUDIT CONFIGURATION
# ============================================================================
AUDIT_LOG_RETENTION_DAYS=365
AUDIT_LOG_EXPORT_FORMAT=json

# ============================================================================
# FEATURE FLAGS
# ============================================================================
ENABLE_2FA=false
ENABLE_AUDIT_EXPORT=true
ENABLE_API_DOCS=true

# ============================================================================
# EXTERNAL SERVICES (for future integrations)
# ============================================================================
EXTERNAL_API_URL=https://api.yourdomain.com
STRIPE_API_KEY=sk_test_your_stripe_key
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token

# ============================================================================
# ANALYTICS (for future use)
# ============================================================================
ANALYTICS_ENDPOINT=https://analytics.yourdomain.com
ANALYTICS_API_KEY=your_analytics_key

# ============================================================================
# DEPLOYMENT CONFIGURATION
# ============================================================================
ENVIRONMENT=production
DEPLOYMENT_REGION=us-east-1
DEPLOYMENT_VERSION=12.0.0
